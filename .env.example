# Supabase — copiar como .env y completar con los valores del Dashboard:
# Project Settings → API → Project API Keys

# URL del proyecto (ej: https://xxxx.supabase.co)
VITE_SUPABASE_URL=

# Anon key en formato JWT (empieza con eyJ...) — NO usar la Publishable Key (sb_publishable_...)
VITE_SUPABASE_ANON_KEY=
